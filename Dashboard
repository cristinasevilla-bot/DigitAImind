<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DigitAImind · Admin</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050d0e;
    --surface: #0a1a1c;
    --border: #112426;
    --accent: #2a7c8a;
    --accent-light: #3aa0b0;
    --accent2: #b87333;
    --accent2-light: #d4894a;
    --text: #e0eeef;
    --muted: #5a7d82;
    --success: #4ade80;
    --warning: #b87333;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
  }

  /* LOGIN */
  #login-screen {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background: radial-gradient(ellipse at 30% 50%, #0a2a2e 0%, var(--bg) 60%);
  }

  .login-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    width: 380px;
    animation: fadeUp 0.5s ease;
  }

  .login-logo {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 8px;
  }

  .login-logo span { color: var(--accent); }

  .login-sub {
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    margin-bottom: 36px;
  }

  .input-group {
    margin-bottom: 16px;
  }

  .input-group label {
    display: block;
    font-size: 11px;
    font-family: 'DM Mono', monospace;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  .input-group input {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
  }

  .input-group input:focus { border-color: var(--accent); }

  .btn-primary {
    width: 100%;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 14px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    margin-top: 8px;
    transition: opacity 0.2s, transform 0.1s;
  }

  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-primary:active { transform: translateY(0); }

  .login-error {
    color: var(--accent2);
    font-size: 12px;
    font-family: 'DM Mono', monospace;
    margin-top: 12px;
    display: none;
  }

  /* DASHBOARD */
  #dashboard { display: none; }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 32px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .logo {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .logo span { color: var(--accent); }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .status-dot {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    animation: pulse 2s infinite;
  }

  .btn-logout {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 6px;
    padding: 6px 14px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-logout:hover { border-color: var(--accent2); color: var(--accent2); }

  .main {
    padding: 32px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 4px;
  }

  .page-sub {
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    margin-bottom: 32px;
  }

  /* STATS */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    animation: fadeUp 0.4s ease both;
  }

  .stat-card:nth-child(1) { animation-delay: 0.1s; }
  .stat-card:nth-child(2) { animation-delay: 0.2s; }
  .stat-card:nth-child(3) { animation-delay: 0.3s; }
  .stat-card:nth-child(4) { animation-delay: 0.4s; }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .stat-value {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-value.accent { color: var(--accent); }
  .stat-value.accent2 { color: var(--accent2); }
  .stat-value.success { color: var(--success); }

  .stat-change {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }

  /* GRID */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    animation: fadeUp 0.5s ease both;
  }

  .card:nth-child(1) { animation-delay: 0.2s; }
  .card:nth-child(2) { animation-delay: 0.3s; }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
  }

  .card-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }

  .card-badge {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 8px;
  }

  /* BOOKING LIST */
  .booking-list { padding: 0; }

  .booking-item {
    display: flex;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
    gap: 16px;
  }

  .booking-item:last-child { border-bottom: none; }
  .booking-item:hover { background: rgba(124, 106, 255, 0.04); }

  .booking-time {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--accent);
    min-width: 52px;
    font-weight: 500;
  }

  .booking-info { flex: 1; }

  .booking-name {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .booking-service {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }

  .booking-status {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .status-confirmed {
    background: rgba(74, 222, 128, 0.1);
    color: var(--success);
    border: 1px solid rgba(74, 222, 128, 0.2);
  }

  .status-pending {
    background: rgba(251, 191, 36, 0.1);
    color: var(--warning);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  /* CONVERSATIONS */
  .conv-list { padding: 0; }

  .conv-item {
    display: flex;
    align-items: flex-start;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    gap: 12px;
    transition: background 0.15s;
  }

  .conv-item:last-child { border-bottom: none; }
  .conv-item:hover { background: rgba(124, 106, 255, 0.04); }

  .conv-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .conv-info { flex: 1; min-width: 0; }

  .conv-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 4px;
  }

  .conv-phone {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--text);
    font-weight: 500;
  }

  .conv-time {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }

  .conv-last {
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* TEST PANEL */
  .test-panel {
    margin-top: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    animation: fadeUp 0.6s ease both;
    animation-delay: 0.4s;
  }

  .test-messages {
    height: 200px;
    overflow-y: auto;
    padding: 16px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .msg {
    max-width: 70%;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px;
    line-height: 1.4;
  }

  .msg-user {
    background: var(--accent);
    color: white;
    align-self: flex-end;
    border-bottom-right-radius: 2px;
  }

  .msg-bot {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    align-self: flex-start;
    border-bottom-left-radius: 2px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
  }

  .test-input-area {
    display: flex;
    gap: 0;
    border-top: 1px solid var(--border);
  }

  .test-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 14px 20px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    outline: none;
  }

  .test-input::placeholder { color: var(--muted); }

  .btn-send {
    background: var(--accent);
    color: white;
    border: none;
    padding: 14px 24px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn-send:hover { opacity: 0.85; }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .typing {
    display: flex;
    gap: 4px;
    padding: 10px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    border-bottom-left-radius: 2px;
    align-self: flex-start;
    width: fit-content;
  }

  .typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--muted);
    animation: bounce 1.2s infinite;
  }

  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-6px); }
  }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">Digit<span>AI</span>mind</div>
    <div class="login-sub">// admin panel · booking bot</div>
    <div class="input-group">
      <label>Usuario</label>
      <input type="text" id="username" placeholder="admin" />
    </div>
    <div class="input-group">
      <label>Contraseña</label>
      <input type="password" id="password" placeholder="••••••••" onkeydown="if(event.key==='Enter') login()" />
    </div>
    <button class="btn-primary" onclick="login()">Entrar</button>
    <div class="login-error" id="login-error">Credenciales incorrectas</div>
  </div>
</div>

<!-- DASHBOARD -->
<div id="dashboard">
  <div class="topbar">
    <div class="logo">Digit<span>AI</span>mind <span style="color:var(--muted);font-size:13px;font-weight:400">/ admin</span></div>
    <div class="topbar-right">
      <div class="status-dot">
        <div class="dot"></div>
        Bot activo
      </div>
      <button class="btn-logout" onclick="logout()">Salir</button>
    </div>
  </div>

  <div class="main">
    <div class="page-title">Panel de control</div>
    <div class="page-sub" id="today-date">// cargando...</div>

    <!-- STATS -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Reservas hoy</div>
        <div class="stat-value accent" id="stat-today">—</div>
        <div class="stat-change">desde Google Calendar</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Esta semana</div>
        <div class="stat-value" id="stat-week">—</div>
        <div class="stat-change">últimos 7 días</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Conversaciones activas</div>
        <div class="stat-value accent2" id="stat-convs">—</div>
        <div class="stat-change">sesiones en memoria</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Estado bot</div>
        <div class="stat-value success" style="font-size:24px">Online ✓</div>
        <div class="stat-change">funcionando correctamente</div>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content-grid">
      <!-- RESERVAS HOY -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">Reservas de hoy</div>
          <div class="card-badge" id="bookings-count">cargando...</div>
        </div>
        <div class="booking-list" id="bookings-list">
          <div style="padding:24px;color:var(--muted);font-family:'DM Mono',monospace;font-size:12px;text-align:center">
            Cargando reservas...
          </div>
        </div>
      </div>

      <!-- CONVERSACIONES -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">Conversaciones recientes</div>
          <div class="card-badge" id="convs-count">—</div>
        </div>
        <div class="conv-list" id="convs-list">
          <div style="padding:24px;color:var(--muted);font-family:'DM Mono',monospace;font-size:12px;text-align:center">
            Sin conversaciones aún
          </div>
        </div>
      </div>
    </div>

    <!-- TEST PANEL -->
    <div class="test-panel">
      <div class="card-header">
        <div class="card-title">🧪 Test del bot</div>
        <div class="card-badge">simulador</div>
      </div>
      <div class="test-messages" id="test-messages">
        <div class="msg msg-bot">Hola! Soy el bot de reservas. ¿En qué puedo ayudarte?</div>
      </div>
      <div class="test-input-area">
        <input class="test-input" id="test-input" placeholder="Escribe un mensaje de prueba..." onkeydown="if(event.key==='Enter') sendTest()" />
        <button class="btn-send" onclick="sendTest()">Enviar →</button>
      </div>
    </div>
  </div>
</div>

<script>
  // ============================================================
  // CONFIG — cambia esto
  // ============================================================
  const ADMIN_USER = "admin";
  const ADMIN_PASS = "digitaimind2024";
  const BOT_URL = ""; // vacío = mismo servidor

  // ============================================================
  // LOGIN
  // ============================================================
  function login() {
    const user = document.getElementById("username").value;
    const pass = document.getElementById("password").value;
    if (user === ADMIN_USER && pass === ADMIN_PASS) {
      document.getElementById("login-screen").style.display = "none";
      document.getElementById("dashboard").style.display = "block";
      initDashboard();
    } else {
      document.getElementById("login-error").style.display = "block";
    }
  }

  function logout() {
    document.getElementById("dashboard").style.display = "none";
    document.getElementById("login-screen").style.display = "flex";
    document.getElementById("username").value = "";
    document.getElementById("password").value = "";
  }

  // ============================================================
  // DASHBOARD INIT
  // ============================================================
  function initDashboard() {
    const now = new Date();
    document.getElementById("today-date").textContent =
      `// ${now.toLocaleDateString("es-ES", { weekday: "long", year: "numeric", month: "long", day: "numeric" })}`;

    loadStats();
    loadBookings();
  }

  // ============================================================
  // STATS
  // ============================================================
  async function loadStats() {
    try {
      const res = await fetch(`${BOT_URL}/admin/stats`);
      if (!res.ok) throw new Error();
      const data = await res.json();
      document.getElementById("stat-today").textContent = data.bookingsToday ?? "—";
      document.getElementById("stat-week").textContent = data.bookingsWeek ?? "—";
      document.getElementById("stat-convs").textContent = data.activeSessions ?? "—";
      document.getElementById("convs-count").textContent = `${data.activeSessions ?? 0} activas`;
    } catch {
      document.getElementById("stat-today").textContent = "—";
      document.getElementById("stat-week").textContent = "—";
      document.getElementById("stat-convs").textContent = "—";
    }
  }

  // ============================================================
  // BOOKINGS
  // ============================================================
  async function loadBookings() {
    try {
      const res = await fetch(`${BOT_URL}/admin/bookings`);
      if (!res.ok) throw new Error();
      const data = await res.json();
      renderBookings(data.bookings || []);
      document.getElementById("bookings-count").textContent = `${(data.bookings || []).length} reservas`;
      document.getElementById("stat-today").textContent = (data.bookings || []).length;
      document.getElementById("stat-week").textContent = data.weekTotal ?? "—";
    } catch {
      renderBookings([]);
      document.getElementById("bookings-count").textContent = "sin datos";
    }
  }

  function renderBookings(bookings) {
    const el = document.getElementById("bookings-list");
    if (!bookings.length) {
      el.innerHTML = `<div style="padding:32px;color:var(--muted);font-family:'DM Mono',monospace;font-size:12px;text-align:center">Sin reservas hoy 🎉</div>`;
      return;
    }
    el.innerHTML = bookings.map(b => `
      <div class="booking-item">
        <div class="booking-time">${b.time}</div>
        <div class="booking-info">
          <div class="booking-name">${b.clientName || "Cliente"}</div>
          <div class="booking-service">${b.service}</div>
        </div>
        <div class="booking-status status-confirmed">confirmada</div>
      </div>
    `).join("");
  }

  // ============================================================
  // TEST BOT
  // ============================================================
  async function sendTest() {
    const input = document.getElementById("test-input");
    const msg = input.value.trim();
    if (!msg) return;

    input.value = "";
    addMessage(msg, "user");

    // Typing indicator
    const typing = document.createElement("div");
    typing.className = "typing";
    typing.innerHTML = "<span></span><span></span><span></span>";
    typing.id = "typing-indicator";
    document.getElementById("test-messages").appendChild(typing);
    scrollMessages();

    try {
      const res = await fetch(`${BOT_URL}/test`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ from: "admin-test", message: msg }),
      });

      // Esperar respuesta del bot (aparece en logs)
      // Como el endpoint /test responde antes de que la IA termine,
      // esperamos un momento y mostramos la respuesta
      await new Promise(r => setTimeout(r, 2500));

      document.getElementById("typing-indicator")?.remove();
      addMessage("✓ Mensaje enviado al bot. Revisa los logs de Render para ver la respuesta completa.", "bot");
    } catch {
      document.getElementById("typing-indicator")?.remove();
      addMessage("Error conectando con el bot.", "bot");
    }
  }

  function addMessage(text, type) {
    const el = document.createElement("div");
    el.className = `msg msg-${type}`;
    el.textContent = text;
    document.getElementById("test-messages").appendChild(el);
    scrollMessages();
  }

  function scrollMessages() {
    const el = document.getElementById("test-messages");
    el.scrollTop = el.scrollHeight;
  }
</script>
</body>
</html>
